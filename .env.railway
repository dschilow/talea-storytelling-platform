# ========================================
# Railway Environment Variables Template
# ========================================
#
# WICHTIG: Diese Datei ist eine Vorlage!
# Setze diese Variables im Railway Dashboard:
# Settings → Variables → New Variable
#
# ODER via Railway CLI:
# railway variables set VARIABLE_NAME=wert
# ========================================

# ==========================================
# 🔐 PFLICHT-SECRETS (MÜSSEN GESETZT WERDEN)
# ==========================================

# Clerk Authentication Secret
# Wo finden: https://dashboard.clerk.com → API Keys → Secret Key
# Format: sk_test_XXXXXX oder sk_live_XXXXXX
ClerkSecretKey=sk_test_DEIN_CLERK_SECRET_KEY_HIER

# Runware AI API Key (für Bildgenerierung)
# Wo finden: https://runware.ai → Dashboard → API Keys
# Format: sk-XXXXXXXXXXXXXXXX
RunwareApiKey=sk-DEIN_RUNWARE_API_KEY_HIER

# ==========================================
# 📱 FRONTEND VARIABLES (wenn separates Frontend Service)
# ==========================================

# Clerk Publishable Key (öffentlich, nicht geheim)
# Wo finden: https://dashboard.clerk.com → API Keys → Publishable Key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_DEIN_PUBLISHABLE_KEY_HIER

# Backend API URL (wird nach erstem Deploy von Railway bereitgestellt)
# Format: https://DEIN-PROJECT-NAME.up.railway.app
VITE_CLIENT_TARGET=https://DEIN-BACKEND-URL.up.railway.app

# ==========================================
# 🤖 OPTIONAL: OpenAI API (für erweiterte Features)
# ==========================================

# OpenAI API Key
# Wo finden: https://platform.openai.com/api-keys
# Format: sk-XXXXXXXXXXXXXXXX
# OPENAI_API_KEY=sk-DEIN_OPENAI_KEY_HIER

# OpenRouter API Key (für OpenRouter Modelle in der Story-Generierung)
# Wo finden: https://openrouter.ai/settings/keys
# Format: sk-or-v1-XXXXXXXXXXXXXXXX
OPENROUTER_API_KEY=sk-or-v1-DEIN_OPENROUTER_KEY_HIER

# ==========================================
# ⚙️ SYSTEM VARIABLES (automatisch von Railway)
# ==========================================
# Diese werden automatisch gesetzt, NICHT manuell ändern:

# PORT - wird von Railway dynamisch zugewiesen
# NODE_ENV=production
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PROJECT_NAME=talea-storytelling-platform
# RAILWAY_SERVICE_NAME=backend

# ==========================================
# 🗄️ POSTGRESQL DATENBANK
# ==========================================

# PostgreSQL Connection URL (automatisch von Railway gesetzt)
# Wird automatisch gesetzt wenn du PostgreSQL hinzufügst:
# Railway Dashboard → + New → Database → Add PostgreSQL
#
# Format: postgresql://user:password@host:port/database
# Encore nutzt diese URL automatisch für alle Datenbanken
#
# DATABASE_URL=postgresql://postgres:xxxxx@containers-us-west.railway.app:5432/railway
#
# ⚠️ WICHTIG: Nicht manuell setzen! Railway setzt das automatisch!
#
# Siehe: RAILWAY_POSTGRESQL_SETUP.md für Details

# ==========================================
# 🔧 DEPLOYMENT CHECKLIST
# ==========================================
#
# [ ] PostgreSQL Datenbank erstellt (+ New → Database → PostgreSQL)
# [ ] DATABASE_URL automatisch gesetzt (von Railway)
# [ ] ClerkSecretKey gesetzt
# [ ] RunwareApiKey gesetzt
# [ ] VITE_CLERK_PUBLISHABLE_KEY gesetzt (Frontend)
# [ ] VITE_CLIENT_TARGET auf Railway URL gesetzt (nach Deploy)
# [ ] Clerk Dashboard: Railway Domain zu authorized parties hinzugefügt
# [ ] Erstes Deployment erfolgreich
# [ ] Logs zeigen "Database migrations completed"
# [ ] Logs überprüft: railway logs
# [ ] Health Check grün
#
# ==========================================

# ==========================================
# 📝 NOTIZEN
# ==========================================
#
# 1. Secrets in Railway setzen via Dashboard:
#    Settings → Variables → + New Variable
#
# 2. ODER via CLI:
#    railway variables set ClerkSecretKey=sk_test_...
#    railway variables set RunwareApiKey=sk-...
#
# 3. Nach Änderungen neu deployen:
#    railway up
#    ODER Git Push (automatisches Deployment)
#
# 4. Logs überwachen:
#    railway logs --follow
#
# ==========================================
